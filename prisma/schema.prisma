generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

///////////////////////
// ENUMS
///////////////////////

enum Role {
  MESTRE
  JOGADOR
}

enum ActionType {
  ATTACK
  TEST
  SKILL
  REACT
  SPELL
  HEAL
  BUFF
  DEBUFF
}

enum AttributeType {
  STRENGTH
  AGILITY
  VIGOR
  INTELLECT
  PRESENCE
}

enum TargetType {
  SELF
  ALLY
  ENEMY
  MULTIPLE
}

enum LogType {
  ROLL
  DAMAGE
  HEAL
  HEAL_OVER_TIME
  DAMAGE_OVER_TIME
  COMBAT_START
  COMBAT_END
  TURN_START
  TURN_END
  MANUAL_OVERRIDE
  REACTION
}

enum StatusType {
  STUNNED
  POISONED
  BURNED
  FROZEN
}

enum EffectType {
  HEAL_OVER_TIME
  DAMAGE_OVER_TIME
}

///////////////////////
// USER
///////////////////////

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  characters Character[]
}

///////////////////////
// CHARACTER
///////////////////////

model Character {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  life    Int
  maxLife Int
  xp      Int

  strength  Int
  agility   Int
  vigor     Int
  intellect Int
  presence  Int

  baseDefense Int     @default(0)
  history     String?

  // Presets automáticos de defesa
  dodgePresetId String?       @db.ObjectId
  dodgePreset   ActionPreset? @relation("DodgePreset", fields: [dodgePresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  blockPresetId String?       @db.ObjectId
  blockPreset   ActionPreset? @relation("BlockPreset", fields: [blockPresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  counterAttackPresetId String?       @db.ObjectId
  counterAttackPreset   ActionPreset? @relation("CounterAttackPreset", fields: [counterAttackPresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  ownerId String @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id])

  presets   ActionPreset[] @relation("CharacterPresets")
  inventory Inventory[]

  actionLogs ActionLog[] @relation("ActionAuthor")
  targetLogs ActionLog[] @relation("ActionTarget")

  combatParticipants CombatParticipant[]
  turns              CombatTurn[]

  rollResults RollResult[]

  // Status temporários
  statusEffects CharacterEffect[]
}

///////////////////////
// ACTION PRESET
///////////////////////

model ActionPreset {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String

  type       ActionType
  targetType TargetType

  diceFormula   String // rolagem de ataque / teste
  impactFormula String? // rolagem de dano OU cura
  modifier      Int     @default(0)

  critThreshold  Int?
  critMultiplier Float?

  requiresTurn     Boolean @default(true)
  allowOutOfCombat Boolean @default(false)
  appliesEffect    Boolean @default(true)

  attribute AttributeType

  durationTurns Int?
  statAffected  AttributeType?
  effectAmount  Int?
  statusApplied StatusType?

  characterId String    @db.ObjectId
  character   Character @relation("CharacterPresets", fields: [characterId], references: [id])

  dodgeCharacters         Character[] @relation("DodgePreset")
  blockCharacters         Character[] @relation("BlockPreset")
  counterAttackCharacters Character[] @relation("CounterAttackPreset")

  rolls            RollResult[]
  inventories      Inventory[]
  characterEffects CharacterEffect[]
}

///////////////////////
// ROLL RESULT
///////////////////////

model RollResult {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String?       @db.ObjectId
  preset   ActionPreset? @relation(fields: [presetId], references: [id])

  combatId String? @db.ObjectId
  combat   Combat? @relation(fields: [combatId], references: [id])

  turnId String?     @db.ObjectId
  turn   CombatTurn? @relation(fields: [turnId], references: [id])

  targetIds String[] @db.ObjectId

  diceRolled String
  rolls      Int[]
  modifier   Int
  total      Int

  success  Boolean? // Será definido após reação do alvo
  critical Boolean

  damage  Int?
  healing Int?

  // Reações
  pendingReaction Boolean @default(false)
  reactionType    String?
  reacted         Boolean @default(false)

  createdAt DateTime @default(now())

  logs ActionLog[] @relation("RollLogs")
}

///////////////////////
// ACTION LOG
///////////////////////

model ActionLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  type    LogType
  message String

  characterId String?    @db.ObjectId
  character   Character? @relation("ActionAuthor", fields: [characterId], references: [id])

  targetId String?    @db.ObjectId
  target   Character? @relation("ActionTarget", fields: [targetId], references: [id])

  rollId String?     @db.ObjectId
  roll   RollResult? @relation("RollLogs", fields: [rollId], references: [id])

  combatId String? @db.ObjectId
  combat   Combat? @relation("CombatLogs", fields: [combatId], references: [id])

  turnId String?     @db.ObjectId
  turn   CombatTurn? @relation("TurnLogs", fields: [turnId], references: [id])

  createdAt DateTime @default(now())
}

///////////////////////
// INVENTORY
///////////////////////

model Inventory {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  quantity    Int
  description String?

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String?       @db.ObjectId // vincula item a preset
  preset   ActionPreset? @relation(fields: [presetId], references: [id])
}

///////////////////////
// COMBAT
///////////////////////

model Combat {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  active Boolean @default(true)
  round  Int     @default(1)

  currentTurnIndex Int @default(0)

  createdAt DateTime @default(now())

  participants CombatParticipant[]
  turns        CombatTurn[]
  logs         ActionLog[]         @relation("CombatLogs")
  rollResults  RollResult[]
}

model CombatParticipant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  combatId String @db.ObjectId
  combat   Combat @relation(fields: [combatId], references: [id])

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  currentLife Int
  initiative  Int?
  turnOrder   Int?
}

///////////////////////
// COMBAT TURNOS
///////////////////////

model CombatTurn {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  combatId String @db.ObjectId
  combat   Combat @relation(fields: [combatId], references: [id])

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  turnNumber Int
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  logs        ActionLog[]  @relation("TurnLogs")
  rollResults RollResult[]
}

///////////////////////
// EFFECTS TEMPORÁRIOS
///////////////////////

model CharacterEffect {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String       @db.ObjectId
  preset   ActionPreset @relation(fields: [presetId], references: [id])

  remainingTurns Int
  appliedAt      DateTime       @default(now())
  type           EffectType
  value          Int
  statAffected   AttributeType?
  statusApplied  StatusType?
}
