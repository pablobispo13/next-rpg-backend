generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

///////////////////////
// ENUMS
///////////////////////

enum Role {
  MESTRE
  JOGADOR
}

enum ActionType {
  ATTACK
  TEST
  SKILL
  REACT
  SPELL
  HEAL
  BUFF
  DEBUFF
  SUPPORT
}

enum AttributeType {
  STRENGTH
  AGILITY
  VIGOR
  INTELLECT
  PRESENCE
}

enum TargetType {
  SELF
  ALLY
  ENEMY
  MULTIPLE
}

enum LogType {
  ROLL
  DAMAGE
  HEAL
  HEAL_OVER_TIME
  DAMAGE_OVER_TIME
  COMBAT_START
  COMBAT_END
  TURN_START
  TURN_END
  MANUAL_OVERRIDE
  REACTION
}

enum StatusType {
  STUNNED
  POISONED
  BURNED
  FROZEN
}

enum EffectType {
  HEAL_OVER_TIME
  DAMAGE_OVER_TIME
  STAT_BUFF
  STAT_DEBUFF
  TEMP_HP
  STUN
  ROLL_BONUS
  ROLL_PENALTY
  ADVANTAGE
  DISADVANTAGE
}

///////////////////////
// USER
///////////////////////

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  email     String   @unique
  password  String
  role      Role
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  characters       Character[]
  ownedCampaigns   Campaign[]         @relation("CampaignMaster")
  campaignMembers  CampaignMember[]
}

///////////////////////
// CAMPAIGN (MESA)
///////////////////////

model Campaign {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  image       String?
  streamUrl   String?
  createdAt   DateTime @default(now())
  archivedAt  DateTime?

  masterId String @db.ObjectId
  master   User   @relation("CampaignMaster", fields: [masterId], references: [id])

  members      CampaignMember[]
  invites      CampaignInvite[]
  characters   Character[]
  combats      Combat[]
}

model CampaignMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([campaignId, userId])
}

model CampaignInvite {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  code      String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
  maxUses   Int?
  uses      Int      @default(0)
  active    Boolean  @default(true)
}

///////////////////////
// CHARACTER
///////////////////////

model Character {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  life      Int
  maxLife   Int
  xp        Int
  strength  Int
  agility   Int
  vigor     Int
  intellect Int
  presence  Int

  baseDefense   Int           @default(0)
  history       String?
  notes         String?
  image         String?
  // Presets automáticos de defesa
  dodgePresetId String?       @db.ObjectId
  dodgePreset   ActionPreset? @relation("DodgePreset", fields: [dodgePresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  blockPresetId String?       @db.ObjectId
  blockPreset   ActionPreset? @relation("BlockPreset", fields: [blockPresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  counterAttackPresetId String?       @db.ObjectId
  counterAttackPreset   ActionPreset? @relation("CounterAttackPreset", fields: [counterAttackPresetId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  ownerId String @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id])

  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  presets   ActionPreset[] @relation("CharacterPresets")
  inventory Inventory[]

  actionLogs ActionLog[] @relation("ActionAuthor")
  targetLogs ActionLog[] @relation("ActionTarget")

  combatParticipants CombatParticipant[]
  turns              CombatTurn[]

  rollResults RollResult[]

  // Status temporários
  statusEffects CharacterEffect[]
}

///////////////////////
// ACTION PRESET
///////////////////////

model ActionPreset {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String

  type       ActionType
  targetType TargetType

  diceFormula   String // rolagem de ataque / teste
  impactFormula String? // rolagem de dano OU cura
  modifier      Int     @default(0)

  critThreshold  Int?
  critMultiplier Float?

  requiresTurn     Boolean @default(true)
  allowOutOfCombat Boolean @default(false)
  appliesEffect    Boolean @default(true)
  isAreaEffect     Boolean @default(false)

  attribute AttributeType

  durationTurns Int?
  statAffected  AttributeType?
  effectAmount  Int?
  statusApplied StatusType?
  effectType    EffectType?

  characterId String    @db.ObjectId
  character   Character @relation("CharacterPresets", fields: [characterId], references: [id])

  dodgeCharacters         Character[] @relation("DodgePreset")
  blockCharacters         Character[] @relation("BlockPreset")
  counterAttackCharacters Character[] @relation("CounterAttackPreset")

  rolls            RollResult[]
  inventories      Inventory[]
  characterEffects CharacterEffect[]
}

///////////////////////
// ROLL RESULT
///////////////////////

model RollResult {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String?       @db.ObjectId
  preset   ActionPreset? @relation(fields: [presetId], references: [id])

  combatId String? @db.ObjectId
  combat   Combat? @relation(fields: [combatId], references: [id])

  turnId String?     @db.ObjectId
  turn   CombatTurn? @relation(fields: [turnId], references: [id])

  targetIds String[] @db.ObjectId

  diceRolled String
  rolls      Int[]
  modifier   Int
  total      Int

  impactRolls Int[] @default([]) // Rolls do dano/cura (ex: [3, 2, 1])

  success  Boolean? // Será definido após reação do alvo
  critical Boolean

  damage  Int?
  healing Int?

  // Reações
  pendingReaction Boolean @default(false)
  reactionType    String?
  reacted         Boolean @default(false)
  pendingReactionTargets Json[] @default([])

  createdAt DateTime @default(now())

  logs    ActionLog[]      @relation("RollLogs")
  details RollResultDetail[] @relation("RollDetails")
}

///////////////////////
// ROLL RESULT DETAIL
///////////////////////

model RollResultDetail {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  rollResultId String    @db.ObjectId
  rollResult   RollResult @relation("RollDetails", fields: [rollResultId], references: [id])

  targetId String @db.ObjectId

  // Antes da ação
  beforeLife Int?

  // Resultado
  succeeded Boolean
  critical  Boolean
  damageApplied Int?
  healingApplied Int?

  // Defesa (para breakdown visual)
  targetDefense Int?
}

///////////////////////
// ACTION LOG
///////////////////////

model ActionLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  type    LogType
  message String

  characterId String?    @db.ObjectId
  character   Character? @relation("ActionAuthor", fields: [characterId], references: [id])

  targetId String?    @db.ObjectId
  target   Character? @relation("ActionTarget", fields: [targetId], references: [id])

  rollId String?     @db.ObjectId
  roll   RollResult? @relation("RollLogs", fields: [rollId], references: [id])

  combatId String? @db.ObjectId
  combat   Combat? @relation("CombatLogs", fields: [combatId], references: [id])

  turnId String?     @db.ObjectId
  turn   CombatTurn? @relation("TurnLogs", fields: [turnId], references: [id])

  createdAt DateTime @default(now())
}

///////////////////////
// INVENTORY
///////////////////////

model Inventory {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  quantity    Int
  description String?

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String?       @db.ObjectId // vincula item a preset
  preset   ActionPreset? @relation(fields: [presetId], references: [id])
}

///////////////////////
// COMBAT
///////////////////////

model Combat {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  active Boolean @default(true)
  round  Int     @default(1)

  currentTurnIndex Int @default(0)

  notes       String?
  streamUrl   String?
  hpSnapshots Json[]  @default([])

  createdAt DateTime @default(now())

  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  participants CombatParticipant[]
  turns        CombatTurn[]
  logs         ActionLog[]         @relation("CombatLogs")
  rollResults  RollResult[]
}

model CombatParticipant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  combatId String @db.ObjectId
  combat   Combat @relation(fields: [combatId], references: [id])

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  currentLife Int
  tempHp      Int @default(0)
  initiative  Int?
  turnOrder   Int?
}

///////////////////////
// COMBAT TURNOS
///////////////////////

model CombatTurn {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  combatId String @db.ObjectId
  combat   Combat @relation(fields: [combatId], references: [id])

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  turnNumber Int
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  logs        ActionLog[]  @relation("TurnLogs")
  rollResults RollResult[]
}

///////////////////////
// EFFECTS TEMPORÁRIOS
///////////////////////

model CharacterEffect {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String    @db.ObjectId
  character   Character @relation(fields: [characterId], references: [id])

  presetId String       @db.ObjectId
  preset   ActionPreset @relation(fields: [presetId], references: [id])

  remainingTurns Int
  appliedAt      DateTime       @default(now())
  type           EffectType
  value          Int
  statAffected   AttributeType?
  statusApplied  StatusType?
}
